# ============================================================
#  Etsy MCP Server — Environment Variables
#  Copy this file to .env.etsy and fill in your values.
#  Never commit your real token file or environment file.
# ============================================================

# REQUIRED: Etsy app API key (keystring)
# Create an app at https://www.etsy.com/developers/register
ETSY_API_KEY=your_etsy_app_keystring

# OPTIONAL: Some Etsy requests/examples include the shared secret as part of
# the x-api-key header. If Etsy rejects requests with only ETSY_API_KEY,
# add the shared secret below and the server will send "key:secret".
ETSY_SHARED_SECRET=

# REQUIRED FOR OAUTH: exact redirect URI registered in your Etsy app settings
# It must be HTTPS and match Etsy app settings exactly.
# Example:
# ETSY_REDIRECT_URI=https://oauth.pstmn.io/v1/callback
ETSY_REDIRECT_URI=

# OPTIONAL: initial scopes requested during etsy_begin_oauth
ETSY_SCOPES=shops_r listings_r listings_w transactions_r

# OPTIONAL: the server can auto-save shop_id after discovery
ETSY_SHOP_ID=

# OPTIONAL: if you already have Etsy OAuth tokens, you can paste them here.
# Otherwise leave blank and use the OAuth helper tools.
ETSY_ACCESS_TOKEN=
ETSY_REFRESH_TOKEN=

# OPTIONAL: local JSON file where exchanged/refreshed Etsy tokens are stored
ETSY_TOKEN_FILE=.etsy_tokens.json

# OPTIONAL: server settings
PORT=8000
MCP_TRANSPORT=streamable-http
